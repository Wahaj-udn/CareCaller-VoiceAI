# =========================
# Required secrets
# =========================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
GEMINI_API_KEY=your_gemini_api_key

# =========================
# Twilio webhook + media stream wiring
# =========================
# Public WSS URL to your running gemini_bridge.py endpoint.
# Example: wss://abcd-1234.ngrok-free.app/media-stream
MEDIA_STREAM_URL=wss://your-public-bridge-host/media-stream

# Public HTTPS URL for your Flask webhook server (port 5000 tunnel)
WEBHOOK_BASE_URL=https://your-public-webhook-host
OUTBOUND_TWIML_URL=https://your-public-webhook-host/voice/outbound
RECORDING_STATUS_CALLBACK_URL=https://your-public-webhook-host/voice/recording
RECORD_CALLS=true
RECORDINGS_DIR=recordings
AUTO_TRANSCRIBE_RECORDINGS=true
WHISPER_TRANSCRIPT_DIR=whisper_transcript
WHISPER_MODEL=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=en
WHISPER_FALLBACK_TO_CPU=false
AUTO_BUILD_FINAL_TRANSCRIPT=true
FINAL_TRANSCRIPT_DIR=final_transcript
AUTO_NORMALIZE_TRANSCRIPT=true
AUTO_SAVE_QA_JSON=true
QA_JSON_DIR=qa_json
AUTO_UPDATE_RESULT_JSON=true

# Call defaults (fill both in E.164 format, e.g. +15551234567)
CALL_TO_NUMBER=
CALL_FROM_NUMBER=

# =========================
# Gemini Live behavior
# =========================
GEMINI_MODEL=gemini-3.1-flash-live-preview
FORCE_ENGLISH=true
ENGLISH_LOCALE=en-US
MISSION_PROMPT=You are a friendly interviewer. Mission: collect caller name, years of Python experience, and current role. Ask naturally and keep responses concise.
# Optional: if set, this file is used instead of MISSION_PROMPT.
MISSION_PROMPT_FILE=
MISSION_KICKOFF=Please greet the caller and begin your interview mission now.

# =========================
# Gemini bridge runtime (gemini_bridge.py)
# =========================
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765
BRIDGE_PATH=/media-stream
INTERRUPT_RMS_THRESHOLD=700
LOG_LEVEL=INFO
CONVERSATION_LOG_FILE=conversation.txt
CONVERSATION_DIR=conversation
CONVERSATION_PER_CALL=true
TRANSCRIPT_NORMALIZER_MODEL=gemini-2.5-flash
NORMALIZED_TRANSCRIPT_DIR=normalized_transcript
TRANSCRIPT_NORMALIZER_GEMINI_API_KEY=

# =========================
# Twilio webhook runtime (server.py)
# =========================
HOST=0.0.0.0
PORT=5000
